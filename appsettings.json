{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Aspire.Hosting.Dcp": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AppHost": {
    "Environment": {
      "LogLevel": "Debug",
      "AspNetCoreEnvironment": "Development",
      "ExtraVariables": {}
    },
    "Services": {
      "sample-api": {
        "ProjectPath": "C:\\Path\\To\\Your\\Sample.Api.csproj",
        "SolutionPath": "C:\\Path\\To\\Your\\Solution.sln",
        "Port": 5000,
        "Active": false,
        "EnvironmentVariables": {}
      },
      "sample-web": {
        "ProjectPath": "C:\\Path\\To\\Your\\Sample.Web.csproj",
        "Port": 5100,
        "Active": false,
        "Certificate": {
          "Path": "C:\\Path\\To\\Your\\cert.pfx",
          "Password": "REPLACE_ME_OR_USE_USER_SECRETS"
        },
        "EnvironmentVariables": {
          "FeatureFlags__EnableSwagger": "true"
        }
      }
    }
  }
}
